{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "meintechblog/affiliate-cards",
  "title": "Affiliate Card",
  "category": "widgets",
  "icon": "cart",
  "description": "Zeigt Amazon-Affiliate-Karten im meintechblog-Stil.",
  "textdomain": "meintechblog-affiliate-cards",
  "editorScript": "mtb-affiliate-cards-editor",
  "editorStyle": "mtb-affiliate-cards-editor",
  "style": "mtb-affiliate-cards-frontend",
  "usesContext": [
    "postId",
    "postType"
  ],
  "attributes": {
    "items": {
      "type": "array",
      "default": []
    },
    "amazonTitle": {
      "type": "string",
      "default": ""
    },
    "detailUrl": {
      "type": "string",
      "default": ""
    },
    "images": {
      "type": "array",
      "default": []
    },
    "selectedImageIndex": {
      "type": "number",
      "default": 0
    },
    "loadState": {
      "type": "string",
      "default": "idle"
    },
    "loadError": {
      "type": "string",
      "default": ""
    },
    "badgeMode": {
      "type": "string",
      "default": "auto"
    },
    "ctaLabel": {
      "type": "string",
      "default": "Preis auf Amazon checken"
    },
    "autoShortenTitles": {
      "type": "boolean",
      "default": true
    }
  },
  "supports": {
    "html": false
  }
}
